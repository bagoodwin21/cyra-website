# CYRA Wellness — environment variables
# Copy to .env.local for development; set the same variables in the
# Vercel project settings for production. All are NEXT_PUBLIC_ because
# they're consumed client-side (embeds, analytics, form submissions).

# Calendly scheduling link for the "Request More Information" / consult
# embed on /book (e.g. https://calendly.com/cyra-wellness/consult)
NEXT_PUBLIC_CALENDLY_URL=

# Google Tag Manager container ID (GTM-XXXXXXX). Analytics stay disabled
# until this is set.
NEXT_PUBLIC_GTM_ID=

# Cherry practice/merchant ID for the financing rate-check widget.
NEXT_PUBLIC_CHERRY_MERCHANT_ID=

# Practice SMS number in E.164 format (e.g. +18055551234). "Text us"
# links (footer, mobile book bar) stay hidden until this is set.
NEXT_PUBLIC_SMS_NUMBER=
