# CYRA Wellness — environment variables
# Copy to .env.local for development; set the same variables in the
# Vercel project settings for production. All are NEXT_PUBLIC_ because
# they're consumed client-side (embeds, analytics, form submissions).

# Calendly scheduling link for the discovery-call embed on /book and
# /how-it-works (e.g. https://calendly.com/cyra-wellness/discovery-call)
NEXT_PUBLIC_CALENDLY_URL=

# HubSpot Forms API destination for quiz email capture (src/lib/hubspot.ts).
# Portal ID is the numeric account ID; Form ID is the form's GUID.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_FORM_ID=

# Google Tag Manager container ID (GTM-XXXXXXX). Analytics stay disabled
# until this is set.
NEXT_PUBLIC_GTM_ID=

# Cherry practice/merchant ID for the rate-check widget on /pricing.
NEXT_PUBLIC_CHERRY_MERCHANT_ID=

# Enrollment-flow handoff links (src/lib/carePlans.ts handoffConfig).
# Both optional — when unset the /enroll handoff step shows manual
# care-coordinator instructions instead of a link. No live API calls
# are made either way.
# Cherry patient application link from the Cherry practice dashboard:
NEXT_PUBLIC_CHERRY_APPLICATION_URL=
# OptiMantra patient portal link (consent packet + card on file):
NEXT_PUBLIC_OPTIMANTRA_PORTAL_URL=
# OptiMantra online-booking link for the paid initial consultation
# (used by the /eligibility pre-booking check):
NEXT_PUBLIC_OPTIMANTRA_BOOKING_URL=

# Superbill practice identifiers (src/lib/superbill.ts). Server-side only,
# not NEXT_PUBLIC — used when generating superbill records, never rendered
# on the marketing site. Superbills fail validation until these are set.
CYRA_PROVIDER_NPI=
CYRA_PRACTICE_EIN=
